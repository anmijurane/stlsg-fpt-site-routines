---
interface Props {
  name: string;
  defaultValue?: string;
  items: Array<{ label: string; value: string; id: string }>;
  spanLastOddItem?: boolean;
  type?: "radio" | "checkbox";
}

const {
  name,
  defaultValue,
  items,
  spanLastOddItem = false,
  type = "radio",
} = Astro.props;
---

<div class="w-full grid grid-cols-2 gap-3">
  {
    items.map((item, idx) => (
      <div
        class="relative flex"
        class:list={{
          "col-span-2":
            spanLastOddItem &&
            items.length % 2 === 1 &&
            idx === items.length - 1,
        }}
      >
        <input
          class="peer sr-only"
          type={type}
          name={name}
          id={item.id}
          value={item.value}
          checked={item.value === defaultValue}
        />
        <label
          for={item.id}
          class="w-full rounded-xl flex justify-center items-center min-h-16 bg-theme-light-card text-theme-purple-dark font-semibold tracking-widest cursor-pointer border-[3px] border-transparent transition peer-checked:border-theme-purple-dark peer-checked:bg-theme-purple-dark peer-checked:text-theme-accent peer-checked:shadow"
        >
          {item.label}
        </label>
      </div>
    ))
  }
</div>
